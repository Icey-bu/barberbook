# ─── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Service role key — NEVER expose to client. Used in server-only code.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Stripe ────────────────────────────────────────────────────────────────────
# Found in: Stripe Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Found in: Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Resend (Transactional Email) ──────────────────────────────────────────────
# Found in: https://resend.com/api-keys
RESEND_API_KEY=re_...

# ─── App ───────────────────────────────────────────────────────────────────────
# The public URL of your deployment (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Internal Security ─────────────────────────────────────────────────────────
# Random secret used to authenticate internal cron job calls
# Generate with: openssl rand -hex 32
INTERNAL_CRON_SECRET=your-random-secret-here
